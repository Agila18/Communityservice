# ============================================
# Vanakkam Akka - Backend Environment Config
# Copy this to .env and fill in your values
# ============================================

# --- App ---
APP_NAME=VanakkamAkka
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this
API_VERSION=v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./vanakkam_akka.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vanakkam_akka

# --- JWT Auth ---
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- OpenAI (for AI health screening) ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4

# --- Firebase ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# --- Agora (Teleconsultation) ---
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# --- Redis (Background tasks) ---
REDIS_URL=redis://localhost:6379/0

# --- SMS / Notifications ---
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# --- Tamil NLP ---
TAMIL_MODEL_PATH=./ai/models/tamil_health_model
TRANSLITERATION_ENABLED=true
