# ============================================
# Vanakkam Akka - Backend Environment Config
# Copy this to .env and fill in your values
# ============================================

# --- App ---
APP_NAME=VanakkamAkka
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this
API_VERSION=v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Database ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost/vanakkam_akka_db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vanakkam_akka

# --- JWT Auth ---
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Gemini API (for AI health screening) ---
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# --- Bhashini API (Tamil NLP) ---
BHASHINI_API_KEY=YOUR_BHASHINI_KEY_HERE
BHASHINI_USER_ID=YOUR_BHASHINI_USER_ID

# --- Firebase ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS=./serviceAccountKey.json

# --- Agora (Teleconsultation) ---
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# --- Redis (Background tasks) ---
REDIS_URL=redis://localhost:6379/0

# --- SMS / Notifications ---
MSG91_API_KEY=YOUR_MSG91_KEY_HERE
MSG91_SENDER_ID=VANAKKAM

# --- Tamil NLP ---
TAMIL_MODEL_PATH=./ai/models/tamil_health_model
TRANSLITERATION_ENABLED=true
